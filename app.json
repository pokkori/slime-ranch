{
  "expo": {
    "name": "slime-ranch",
    "slug": "slime-ranch",
    "version": "1.0.0",
    "description": "スライム牧場 - 可愛いスライムを育てて合体させる放置ゲーム！レアスライムを集めて図鑑を完成させよう。キーワード: スライム育成 放置ゲーム 合体ゲーム マージゲーム 可愛いゲーム",
    "keywords": ["スライム牧場", "放置ゲーム", "スライム", "合体ゲーム", "マージゲーム"],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "slime-ranch",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4CAF50"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pokkori.slimeranch"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4CAF50",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.pokkori.slimeranch"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "title": "スライム牧場 - 放置マージゲーム 全36種スライムを集めよう",
      "description": "スライムを合体させて進化！自動でコインを稼ぐ放置型マージゲーム。",
      "themeColor": "#2d7a3a"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      ["react-native-google-mobile-ads", {
        "androidAppId": "ca-app-pub-3940256099942544~3347511713",
        "iosAppId": "ca-app-pub-3940256099942544~1458002511"
      }]
    ]
  }
}
